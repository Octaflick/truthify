    {
      "parameters": {
        "jsCode": "// Get original form data from Prepare Input node\nconst prep = $('Prepare Input').first().json;\nconst headline     = prep.headline     || 'Unknown';\nconst source       = prep.source       || '';\nconst articleText  = String(prep.content || '');\nconst submitted_at = prep.submitted_at || new Date().toISOString();\n\n// Get Gemini response\nconst gemini = $input.first().json;\nconst raw = gemini?.content?.parts?.[0]?.text\n  || gemini?.text\n  || gemini?.output\n  || gemini?.candidates?.[0]?.content?.parts?.[0]?.text\n  || '';\n\nlet parsed = {};\ntry {\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = {\n    verdict: 'UNVERIFIABLE',\n    confidence_score: 0,\n    key_facts: 'Could not parse AI response: ' + raw.substring(0, 200),\n    emotional_tone: 'unknown',\n    manipulation_score: 0,\n    manipulation_tactics: 'parse error',\n    bias_detected: 'parse error',\n    logical_issues: 'parse error',\n    source_credibility: 'unknown',\n    credibility_score: 0,\n    red_flags: 'ai_parse_error',\n    recommendation: 'Please re-submit the article for analysis.'\n  };\n}\n\nreturn [{\n  json: {\n    submitted_at,\n    headline,\n    source,\n    article_snippet:      articleText.substring(0, 300),\n    verdict:              parsed.verdict              || 'UNVERIFIABLE',\n    confidence_score:     parsed.confidence_score     ?? 0,\n    key_facts:            parsed.key_facts            || '',\n    logical_issues:       parsed.logical_issues       || 'none detected',\n    red_flags:            parsed.red_flags            || 'none',\n    recommendation:       parsed.recommendation       || '',\n    emotional_tone:       parsed.emotional_tone       || 'unknown',\n    manipulation_score:   parsed.manipulation_score   ?? 0,\n    manipulation_tactics: parsed.manipulation_tactics || 'none',\n    bias_detected:        parsed.bias_detected        || 'none detected',\n    source_credibility:   parsed.source_credibility   || 'unknown',\n    credibility_score:    parsed.credibility_score    ?? 0\n  }\n}];"
      },
